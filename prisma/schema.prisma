generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  role      UserRole   @default(RECRUITER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  logs      AuditLog[]
  notes     Note[]
}

model Candidate {
  id                 String          @id @default(uuid())
  firstName          String
  middleName         String?
  lastName           String
  phone              String?
  email              String?
  dateOfBirth        DateTime?
  placeOfBirth       String?
  countryOfBirth     String?
  citizenship        String?
  nationality        String?
  sex                String?
  maritalStatus      String?
  education          String?
  estimatedArrival   DateTime?
  needsHousing       Boolean         @default(false)
  observations       String?
  status             CandidateStatus @default(NEW)
  consentContact     Boolean         @default(false)
  consentRecruitment Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  documents          Document[]
  notes              Note[]
  history            StatusHistory[]
}

model Document {
  id               String    @id @default(uuid())
  candidateId      String
  type             String
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  confidence       Float?
  dateOfExpiry     DateTime?
  dateOfIssue      DateTime?
  documentNumber   String?
  extractedJson    Json?
  extractionStatus String    @default("PENDING")
  identityNumber   String?
  issuingCountry   String?
  mrzRaw           String?
  ocrText          String?
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Note {
  id          String    @id @default(uuid())
  candidateId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
}

model StatusHistory {
  id          String          @id @default(uuid())
  candidateId String
  fromStatus  CandidateStatus
  toStatus    CandidateStatus
  changedBy   String?
  createdAt   DateTime        @default(now())
  candidate   Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  RECRUITER
  VIEWER
}

enum CandidateStatus {
  NEW
  CONTACTED
  UNDER_REVIEW
  INTERVIEW
  PENDING_DOCS
  APPROVED
  REJECTED
  HIRED
}
